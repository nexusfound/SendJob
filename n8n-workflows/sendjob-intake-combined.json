      "id": "node-patch-job",
      "name": "Assign Job",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2600, 200]
    },
    {
      "parameters": {
        "jsCode": "const jobId = $('Get Latest New Job').item.json.id;\nconst jobShort = jobId.slice(-6).toUpperCase();\nconst techName = $('Get Tech by Name').item.json.name;\nconst dispatcherPhone = $('Parse SMS Fields').item.json.from_phone;\nconst fromNumber = $('Get Client by Phone').item.json.twilio_number;\n\nif (!jobId) throw new Error('[E02S02] job ID missing');\nif (!techName) throw new Error('[E02S02] tech name missing');\nif (!dispatcherPhone) throw new Error('[E02S02] dispatcher phone missing');\nif (!fromNumber) throw new Error('[E02S02] from_number missing');\n\nconst confirmMsg = `Job #${jobShort} assigned to ${techName}.`;\n\nreturn [{\n  json: {\n    confirmation_msg: confirmMsg,\n    dispatcher_phone: dispatcherPhone,\n    from_number: fromNumber\n  }\n}];"
      },
      "id": "node-build-confirm",
      "name": "Build Confirmation SMS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2840, 200]
    },
    {
      "parameters": {
        "from": "={{ $('Build Confirmation SMS').item.json.from_number }}",
        "to": "={{ $('Build Confirmation SMS').item.json.dispatcher_phone }}",
        "message": "={{ $('Build Confirmation SMS').item.json.confirmation_msg }}"
      },
      "id": "node-send-sms",
      "name": "Send Confirmation SMS",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [3080, 200],
      "continueOnFail": true,
      "credentials": {
        "twilioApi": {
