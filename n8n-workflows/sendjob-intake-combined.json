        "options": {}
      },
      "id": "node-fetch-all-techs",
      "name": "Fetch All Techs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2120, 400]
    },
    {
      "parameters": {
        "jsCode": "const allTechs = $input.all();\nconst techNames = allTechs.map(item => item.json.name).filter(Boolean).join(', ');\nconst attempted = $('Extract Tech Name').item.json.tech_name;\nconst dispatcherPhone = $('Parse SMS Fields').item.json.from_phone;\nconst fromNumber = $('Get Client by Phone').item.json.twilio_number;\n\nif (!dispatcherPhone) throw new Error('[E02S03] dispatcher_phone missing');\nif (!fromNumber) throw new Error('[E02S03] from_number (twilio_number) missing');\n\nconst errorMsg = `No match for '${attempted}'. Valid techs: ${techNames}. Reply with a name to assign.`;\n\nreturn [{\n  json: {\n    error_msg: errorMsg,\n    dispatcher_phone: dispatcherPhone,\n    from_number: fromNumber\n  }\n}];"
      },
      "id": "node-build-error-sms",
      "name": "Build Error SMS",
