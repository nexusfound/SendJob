      "parameters": {
        "jsCode": "const rawText = $('Parse SMS Fields').item.json.message_body || '';\nconst techName = rawText.trim();\nif (!techName) {\n  throw new Error('[E02S02] Empty message_body — no tech name to match');\n}\nreturn [{ json: { tech_name: techName } }];"
